{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22",
    "python": "3.13"
  },
  "steps": {
    "install-frontend": {
      "inputs": [
        { "step": "packages:mise" },
        { "local": true, "include": ["."] }
      ],
      "commands": [
        "cd frontend && npm install"
      ]
    },
    "build-frontend": {
      "inputs": [{ "step": "install-frontend" }],
      "commands": [
        "cd frontend && npm run build",
        "cp -r frontend/dist /app/backend/static"
      ],
      "deployOutputs": [
        { "include": ["/app/backend"] }
      ]
    },
    "install-python": {
      "inputs": [{ "step": "build-frontend" }],
      "commands": [
        "pip install -r requirements.txt"
      ],
      "deployOutputs": [
        { "include": ["/app"] }
      ]
    }
  },
  "deploy": {
    "startCommand": "python -m uvicorn app:app --host 0.0.0.0 --port $PORT",
    "inputs": [
      {
        "step": "install-python",
        "include": [
          "/app",
          "/mise/shims",
          "/mise/installs",
          "/usr/local/bin/mise",
          "/etc/mise/config.toml",
          "/root/.local/state/mise"
        ]
      }
    ],
    "paths": ["/mise/shims"]
  }
}