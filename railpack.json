{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22",
    "python": "3.13"
  },
  "steps": {
    "install-frontend": {
      "inputs": ["."],
      "commands": [
        "cd frontend && npm install"
      ]
    },
    "build-frontend": {
      "inputs": ["install-frontend"],
      "commands": [
        "cd frontend && npm run build",
        "cp -r dist /app/backend/static"
      ],
      "deployOutputs": [
        { "include": ["/app/backend"] }
      ]
    },
    "install-python": {
      "inputs": ["build-frontend"],
      "commands": [
        "pip install -r requirements.txt"
      ],
      "deployOutputs": [
        { "include": ["/app"] }
      ]
    }
  },
  "deploy": {
    "startCommand": "python -m uvicorn app:app --host 0.0.0.0 --port $PORT",
    "inputs": ["install-python"]
  }
}